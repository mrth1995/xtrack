# xtrack environment variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
#
# SECURITY: Service-role keys grant unrestricted database access and must
# NEVER appear in the browser bundle, client-side code, or PUBLIC_ prefixed
# variables. Keep them in server-only contexts (hooks.server.ts, server routes,
# GitHub Actions secrets) exclusively.

# ── Browser-safe (PUBLIC_ prefix = readable by client JS) ────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only (no PUBLIC_ prefix — never in client bundle) ─────────────────
SUPABASE_PROJECT_REF=
